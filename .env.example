# ============================================
# CoRegula AI-Engine Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Server Configuration
HOST=0.0.0.0
PORT=8001
ENV=development
DEBUG=true

# OpenAI Compatible API (GLM-4.7)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://43.228.214.145:8317/v1
OPENAI_MODEL=glm-4.7
OPENAI_EMBEDDING_MODEL=embedding-2
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048

# Google Gemini API (Gemini 2.5 Flash) - Legacy, kept for compatibility
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.95
GEMINI_MAX_OUTPUT_TOKENS=2048

# Vector Database (ChromaDB)
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_PREFIX=coregula

# PDF Processing
MAX_FILE_SIZE_MB=10
MAX_UPLOAD_SIZE_MB=10
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# RAG Configuration
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.7

# Core-API Integration
CORE_API_URL=http://localhost:3000
CORE_API_SECRET=shared-secret-key

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=coregula
ENABLE_MONGODB_LOGGING=true

# Efficiency Guard Configuration
ENABLE_EFFICIENCY_GUARD=true
CACHE_TTL_SECONDS=3600
MAX_CACHE_SIZE=1000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60